# Database configuration
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/ai_interview_helper
REDIS_URL=redis://localhost:6379

# JWT configuration - 请修改为强密码
SECRET_KEY=your-secret-key-change-this-in-production-use-strong-password
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS configuration
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# 可选：调试模式
DEBUG=False

# 可选：日志级别
LOG_LEVEL=INFO